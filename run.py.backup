@app.route('/admin/api/dispute/<int:dispute_id>', methods=['POST'])
def admin_update_dispute(dispute_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    admin = UserProfile.query.get(session['user_id'])
    if not admin or admin.email != 'admin@epaisa.com':
        return jsonify({"error": "Forbidden"}), 403
    from database_layer import Dispute
    dispute = Dispute.query.get(dispute_id)
    if not dispute:
        return jsonify({"error": "Not found"}), 404
    data = request.get_json() or {}
    if 'status' in data:
        dispute.status = data['status']
        if data['status'] == 'resolved':
            dispute.resolved_at = datetime.now(timezone.utc)
    db.session.commit()
    return jsonify({"success": True})

@app.route('/admin/api/refund/<int:dispute_id>', methods=['POST'])
def admin_refund_dispute(dispute_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    admin = UserProfile.query.get(session['user_id'])
    if not admin or admin.email != 'admin@epaisa.com':
        return jsonify({"error": "Forbidden"}), 403
    from database_layer import Dispute
    dispute = Dispute.query.get(dispute_id)
    if not dispute:
        return jsonify({"error": "Not found"}), 404
    txn = Transaction.query.filter_by(id=dispute.txn_id).first()
    if txn:
        user = UserProfile.query.get(txn.user_id)
        if user and (txn.txn_type == 'debit' or txn.tx_type == 'debit'):
            user.balance = (user.balance or user.wallet_balance or 0) + txn.amount
            user.wallet_balance = user.balance
            refund_txn = Transaction(
                id=f"TXN-{random.randint(100000, 999999)}-REF",
                user_id=user.id,
                tx_type='credit',
                txn_type='credit',
                amount=txn.amount,
                running_balance=user.balance,
                status='success',
                txn_status='success',
                reference=f"Refund: {dispute.txn_id}"
            )
            db.session.add(refund_txn)
    dispute.status = 'resolved'
    dispute.resolved_at = datetime.now(timezone.utc)
    db.session.commit()
    return jsonify({"success": True})






