# ---------- #31 REPORT WRONG TRANSACTION ----------

@app.route('/report-transaction', methods=['GET', 'POST'])
def report_transaction():
    if 'user_id' not in session:
        flash("Login required.", "danger")
        return redirect(url_for('login'))
    user = UserProfile.query.get(session['user_id'])
    if not user:
        flash("User not found.", "danger")
        return redirect(url_for('logout'))
    if request.method == 'POST':
        txn_id = request.form.get('txn_id', '').strip()
        issue_type = request.form.get('issue_type', '').strip()
        description = request.form.get('description', '').strip()
        resolution = request.form.get('resolution', 'investigation').strip()
        if not txn_id or not issue_type or not description:
            flash("All fields are required.", "danger")
            return redirect(url_for('report_transaction'))
        txn = Transaction.query.filter_by(id=txn_id, user_id=user.id).first()
        if not txn:
            flash("Transaction not found or does not belong to you.", "danger")
            return redirect(url_for('report_transaction'))
        from database_layer import Dispute
        dispute = Dispute(
            user_id=user.id,
            txn_id=txn_id,
            issue_type=issue_type,
            description=description,
            resolution=resolution
        )
        db.session.add(dispute)
        db.session.commit()
        flash("Report submitted successfully. We will investigate within 24 hours.", "success")
        return redirect(url_for('report_transaction'))
    from database_layer import Dispute
    disputes = Dispute.query.filter_by(user_id=user.id).order_by(Dispute.created_at.desc()).all()
    return render_template('report_transaction.html', disputes=disputes)

