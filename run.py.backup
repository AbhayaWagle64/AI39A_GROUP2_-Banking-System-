@app.route('/admin/export/<report_type>')
def admin_export_report(report_type):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    from_date = request.args.get('from')
    to_date = request.args.get('to')
    if report_type == 'users':
        users = UserProfile.query.all()
        csv = "ID,Name,Email,Phone,Balance,Verified,Banned,Created\n"
        for u in users:
            csv += f"{u.id},{u.name or u.fullname},{u.email},{u.phone},{u.balance or u.wallet_balance},{u.is_verified},{getattr(u, 'is_banned', False)},{u.created_at}\n"
        return Response(csv, mimetype='text/csv',
            headers={"Content-Disposition": f"attachment;filename=users_report_{datetime.now().strftime('%Y%m%d')}.csv"})
    elif report_type == 'transactions':
        txns = Transaction.query.all()
        csv = "ID,User,Type,Amount,Status,Reference,Date\n"
        for t in txns:
            csv += f"{t.id},{t.user_id},{t.txn_type or t.tx_type},{t.amount},{t.status or t.txn_status},{t.reference},{t.timestamp}\n"
        return Response(csv, mimetype='text/csv',
            headers={"Content-Disposition": f"attachment;filename=transactions_report_{datetime.now().strftime('%Y%m%d')}.csv"})
    elif report_type == 'revenue':
        txns = Transaction.query.filter(Transaction.txn_type == 'credit').all()
        total = sum(t.amount for t in txns)
        csv = f"Total Revenue,Rs. {total:.2f}\nTransaction Count,{len(txns)}\n"
        return Response(csv, mimetype='text/csv',
            headers={"Content-Disposition": f"attachment;filename=revenue_report_{datetime.now().strftime('%Y%m%d')}.csv"})
    elif report_type == 'disputes':
        from database_layer import Dispute
        disputes = Dispute.query.all()
        csv = "ID,User,TXN ID,Type,Status,Resolution,Created\n"
        for d in disputes:
            csv += f"{d.id},{d.user_id},{d.txn_id},{d.issue_type},{d.status},{d.resolution},{d.created_at}\n"
        return Response(csv, mimetype='text/csv',
            headers={"Content-Disposition": f"attachment;filename=disputes_report_{datetime.now().strftime('%Y%m%d')}.csv"})
    return jsonify({"error": "Unknown report type"}), 400

