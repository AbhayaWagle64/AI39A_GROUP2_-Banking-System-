# ---------- #26 ADMIN DASHBOARD ----------

@app.route('/admin')
def admin_dashboard():
    if 'user_id' not in session:
        flash("Login required.", "danger")
        return redirect(url_for('login'))
    user = UserProfile.query.get(session['user_id'])
    if not user or user.email != 'admin@epaisa.com':
        flash("Admin access required.", "danger")
        return redirect(url_for('dashboard'))

    total_users = UserProfile.query.count()
    total_transactions = Transaction.query.count()
    total_volume = db.session.query(db.func.sum(Transaction.amount)).scalar() or 0
    verified_users = UserProfile.query.filter_by(is_verified=True).count()

    today = datetime.now(timezone.utc).date()
    today_start = datetime.combine(today, datetime.min.time(), tzinfo=timezone.utc)
    new_users_today = UserProfile.query.filter(UserProfile.created_at >= today_start).count()
    today_txns = Transaction.query.filter(Transaction.timestamp >= today_start).all()
    transactions_today = len(today_txns)

    chart_labels = []
    chart_volume = []
    chart_users = []
    for i in range(6, -1, -1):
        day = datetime.now(timezone.utc).date() - timedelta(days=i)
        day_start = datetime.combine(day, datetime.min.time(), tzinfo=timezone.utc)
        day_end = datetime.combine(day, datetime.max.time(), tzinfo=timezone.utc)
        day_txns = Transaction.query.filter(Transaction.timestamp >= day_start, Transaction.timestamp <= day_end).all()
        day_volume = sum(t.amount for t in day_txns)
        day_users = UserProfile.query.filter(UserProfile.created_at >= day_start, UserProfile.created_at <= day_end).count()
        chart_labels.append(day.strftime('%a'))
        chart_volume.append(float(day_volume))
        chart_users.append(day_users)

    users = UserProfile.query.all()
    transactions = Transaction.query.order_by(Transaction.timestamp.desc()).limit(50).all()

    return render_template('admin.html',
        stats={
            'total_users': total_users,
            'total_transactions': total_transactions,
            'total_volume': total_volume,
            'verified_users': verified_users,
            'new_users_today': new_users_today,
            'transactions_today': transactions_today
        },
        users=users,
        transactions=transactions,
        chart_labels=chart_labels,
        chart_volume=chart_volume,
        chart_users=chart_users,
        now=datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M UTC')
    )

# ---------- #27 USER MANAGEMENT ----------

@app.route('/admin/users')
def admin_users():
    if 'user_id' not in session:
        flash("Login required.", "danger")
        return redirect(url_for('login'))
    user = UserProfile.query.get(session['user_id'])
    if not user or user.email != 'admin@epaisa.com':
        flash("Admin access required.", "danger")
        return redirect(url_for('dashboard'))
    users = UserProfile.query.all()
    return render_template('admin_users.html', users=users)

@app.route('/admin/api/user/<int:user_id>')
def admin_user_detail(user_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    admin = UserProfile.query.get(session['user_id'])
    if not admin or admin.email != 'admin@epaisa.com':
        return jsonify({"error": "Forbidden"}), 403
    target = UserProfile.query.get(user_id)
    if not target:
        return jsonify({"error": "Not found"}), 404
    return jsonify({
        "id": target.id,
        "name": target.name or target.fullname,
        "email": target.email,
        "phone": target.phone,
        "balance": target.balance or target.wallet_balance,
        "is_verified": target.is_verified,
        "is_banned": getattr(target, 'is_banned', False),
        "created_at": target.created_at.isoformat() if target.created_at else None
    })

@app.route('/admin/api/user/<int:user_id>', methods=['POST'])
def admin_update_user(user_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    admin = UserProfile.query.get(session['user_id'])
    if not admin or admin.email != 'admin@epaisa.com':
        return jsonify({"error": "Forbidden"}), 403
    target = UserProfile.query.get(user_id)
    if not target:
        return jsonify({"error": "Not found"}), 404
    data = request.get_json() or {}
    if 'name' in data:
        target.name = data['name']
        target.fullname = data['name']
    if 'phone' in data:
        target.phone = data['phone']
    if 'balance' in data:
        target.balance = data['balance']
        target.wallet_balance = data['balance']
    db.session.commit()
    return jsonify({"success": True})

@app.route('/admin/api/toggle-ban/<int:user_id>', methods=['POST'])
def admin_toggle_ban(user_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    admin = UserProfile.query.get(session['user_id'])
    if not admin or admin.email != 'admin@epaisa.com':
        return jsonify({"error": "Forbidden"}), 403
    target = UserProfile.query.get(user_id)
    if not target:
        return jsonify({"error": "Not found"}), 404
    target.is_banned = not getattr(target, 'is_banned', False)
    if target.is_banned:
        target.banned_at = datetime.now(timezone.utc)
    db.session.commit()
    return jsonify({"success": True, "is_banned": target.is_banned})

@app.route('/admin/api/delete-user/<int:user_id>', methods=['POST'])
def admin_delete_user(user_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    admin = UserProfile.query.get(session['user_id'])
    if not admin or admin.email != 'admin@epaisa.com':
        return jsonify({"error": "Forbidden"}), 403
    target = UserProfile.query.get(user_id)
    if not target:
        return jsonify({"error": "Not found"}), 404
    Transaction.query.filter_by(user_id=user_id).delete()
    db.session.delete(target)
    db.session.commit()
    return jsonify({"success": True})

# ---------- #28 TRANSACTION MONITORING ----------

@app.route('/admin/transactions')
def admin_transactions():
    if 'user_id' not in session:
        flash("Login required.", "danger")
        return redirect(url_for('login'))
    user = UserProfile.query.get(session['user_id'])
    if not user or user.email != 'admin@epaisa.com':
        flash("Admin access required.", "danger")
        return redirect(url_for('dashboard'))
    transactions = Transaction.query.order_by(Transaction.timestamp.desc()).all()
    today = datetime.now(timezone.utc).date()
    today_start = datetime.combine(today, datetime.min.time(), tzinfo=timezone.utc)
    today_txns = [t for t in transactions if t.timestamp and t.timestamp >= today_start]
    return render_template('admin_transactions.html',
        transactions=transactions,
        today_count=len(today_txns),
        today_volume=sum(t.amount for t in today_txns),
        avg_amount=sum(t.amount for t in transactions) / len(transactions) if transactions else 0,
        flagged_count=len([t for t in transactions if t.amount > 10000])
    )

@app.route('/admin/api/transaction/<txn_id>')
def admin_transaction_detail(txn_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    txn = Transaction.query.filter_by(id=txn_id).first()
    if not txn:
        return jsonify({"error": "Not found"}), 404
    return jsonify({
        "id": txn.id,
        "user_id": txn.user_id,
        "type": txn.txn_type or txn.tx_type,
        "amount": txn.amount,
        "status": txn.status or txn.txn_status,
        "reference": txn.reference,
        "timestamp": txn.timestamp.isoformat() if txn.timestamp else None
    })

@app.route('/admin/api/flag-transaction/<txn_id>', methods=['POST'])
def admin_flag_transaction(txn_id):
    if 'user_id' not in session:
        return jsonify({"error": "Unauthorized"}), 401
    txn = Transaction.query.filter_by(id=txn_id).first()
    if not txn:
        return jsonify({"error": "Not found"}), 404
    txn.status = 'disputed'
    txn.txn_status = 'disputed'
    db.session.commit()
    return jsonify({"success": True})

